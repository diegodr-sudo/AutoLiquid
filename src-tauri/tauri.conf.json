{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "AutoLiquid",
  "version": "1.0.4",
  "identifier": "com.autoliquid.app",
  "build": {
    "frontendDist": "../frontend/out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "cd frontend && npm run dev",
    "beforeBuildCommand": "cd frontend && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "AutoLiquid",
        "width": 800,
        "height": 600,
        "dragDropEnabled": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/api"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "nsis-hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDREMkJEREU2MzM0OTc1M0EKUldRNmRVa3o1dDByVGRJNWlvMmFYeWROd1dlOGl5dVhIRXUrSk14czBEZlV1VDZJdUw2SEpZdDYK",
      "endpoints": [
        "https://github.com/diegodr-sudo/AutoLiquid/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
