<file path=".github/workflows/release.yml">
name: Release

on:
  push:
    tags:
      - "v*"   # Dispara ao criar uma tag: git tag v1.0.0 && git push --tags

jobs:
  release:
    permissions:
      contents: write

    strategy:
      fail-fast: false
      matrix:
        include:
          - platform: macos-14
            target: aarch64-apple-darwin
            args: "--target aarch64-apple-darwin"
            python-arch: arm64
            sidecar-bin: api-aarch64-apple-darwin
            signed-asset: AutoLiquid-macos-arm64.zip
          - platform: windows-latest
            target: x86_64-pc-windows-msvc
            args: "--target x86_64-pc-windows-msvc"
            python-arch: x64
            sidecar-bin: api-x86_64-pc-windows-msvc.exe

    runs-on: ${{ matrix.platform }}

    steps:
      # ── Checkout ────────────────────────────────────────────────────────────
      - name: Checkout
        uses: actions/checkout@v4

      # ── Node.js ─────────────────────────────────────────────────────────────
      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: "20"
          cache: "npm"
          cache-dependency-path: |
            package-lock.json
            frontend/package-lock.json

      # ── Rust ────────────────────────────────────────────────────────────────
      - name: Setup Rust
        shell: bash
        run: |
          rustup toolchain install stable --no-self-update
          rustup default stable
          rustup target add ${{ matrix.target }}

      - name: Rust cache
        uses: swatinem/rust-cache@v2
        with:
          workspaces: "./src-tauri -> target"

      # ── Python ──────────────────────────────────────────────────────────────
      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"
          cache: "pip"
          cache-dependency-path: requirements.txt

      - name: Sync app version from tag
        shell: bash
        run: |
          VERSION="${GITHUB_REF_NAME#v}"
          echo "Sincronizando versao ${VERSION} a partir da tag ${GITHUB_REF_NAME}"
          python - "$VERSION" <<'PY'
          import json
          import pathlib
          import sys

          version = sys.argv[1].lstrip("v").strip()
          if not version:
              raise SystemExit("Versao da tag nao encontrada.")

          tauri_conf = pathlib.Path("src-tauri/tauri.conf.json")
          data = json.loads(tauri_conf.read_text(encoding="utf-8"))
          data["version"] = version
          tauri_conf.write_text(json.dumps(data, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
          print(f"tauri.conf.json -> {version}")
          PY

      - name: Install Python dependencies
        run: python -m pip install -r requirements.txt pyinstaller

      # ── Empacotar backend Python como binário nativo ─────────────────────────
      - name: Build Python sidecar (macOS)
        if: runner.os == 'macOS'
        run: |
          pyinstaller api.spec
          mkdir -p src-tauri/binaries
          cp dist/api src-tauri/binaries/${{ matrix.sidecar-bin }}

      - name: Build Python sidecar (Windows)
        if: runner.os == 'Windows'
        run: |
          pyinstaller api.spec
          mkdir -p src-tauri/binaries
          cp dist/api.exe src-tauri/binaries/${{ matrix.sidecar-bin }}

      # ── Frontend ─────────────────────────────────────────────────────────────
      - name: Install root dependencies (Tauri CLI)
        run: npm ci --no-audit --prefer-offline

      - name: Install frontend dependencies
        run: npm ci --no-audit --prefer-offline
        working-directory: frontend

      # ── Assinatura ad-hoc (macOS) — remove erro "danificado", permite abrir com botão direito ──
      - name: Ad-hoc sign Python sidecar (macOS)
        if: runner.os == 'macOS'
        run: codesign --force --deep --sign - src-tauri/binaries/${{ matrix.sidecar-bin }}

      # ── Build Tauri (gera .dmg e .msi/.exe) ─────────────────────────────────
      - name: Build Tauri app
        uses: tauri-apps/tauri-action@v0
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        with:
          tagName: ${{ github.ref_name }}
          releaseName: "AutoLiquid ${{ github.ref_name }}"
          releaseBody: "Veja os assets abaixo para baixar o instalador."
          releaseDraft: false
          prerelease: false
          args: ${{ matrix.args }}

      - name: Ad-hoc sign macOS app bundle
        if: runner.os == 'macOS'
        run: |
          APP_PATH=$(find "src-tauri/target/${{ matrix.target }}/release/bundle/macos" -maxdepth 1 -name "*.app" -print -quit)
          if [ -z "$APP_PATH" ]; then
            echo "App bundle nao encontrado."
            exit 1
          fi

          codesign --force --deep --sign - "$APP_PATH"
          ditto -c -k --sequesterRsrc --keepParent "$APP_PATH" "${{ matrix.signed-asset }}"

      - name: Upload signed macOS app bundle
        if: runner.os == 'macOS'
        uses: softprops/action-gh-release@v2
        with:
          files: ${{ matrix.signed-asset }}
</file>

