                            + (confirmar && visivel(confirmar) ? 10 : 0)
                            + ((Number.parseInt(did, 10) || 0) / 1000000),
                    };
                }).filter((item) => item.did && item.aindaAberta);

                if (!candidatos.length) return '';
                candidatos.sort((a, b) => b.score - a.score);
                return candidatos[0].did;
            }"""
        ) or ""
    except Exception:
        return ""


