        time.sleep(0.8)
        val = campo.input_value().strip()
        print(f"    Conta de Estoque: '{val}' (digitado: '{codigo}')")
    except Exception as e:
        erros.append(f"Erro ao preencher Conta de Estoque ({codigo}): {e}")


def _preencher_situacao_DSP101_102(
