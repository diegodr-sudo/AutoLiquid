        snapshot = turso.obter_snapshot_fila(timeout=2.5)
    except Exception as exc:
        log.warning("Falha ao carregar snapshot da fila no Turso: %s", exc)
        return None

    rows = _aplicar_de_para_contrato_ic(snapshot.get("rows") or [])
    if not rows:
