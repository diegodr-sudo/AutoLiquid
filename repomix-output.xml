    _fill_date_silente(pagina, f"sfdeducaodtpgtoreceb{did}", data_venc, erros, "Data de Pagamento")

    # â"€â"€ 12b. ValidaÃ§Ã£o final do topo antes da confirmaÃ§Ã£o â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
