                FROM processos p
                JOIN execucoes e ON e.processo_id = p.id
                LEFT JOIN servidores s ON s.id = e.servidor_id
                WHERE {where_sql}
                ORDER BY e.data_execucao DESC, e.id DESC
                LIMIT %s
                """,
                [*params, limite],
            )
            rows_exec = cur.fetchall()

            if not rows_exec:
