  const statusColor = {
    pronto: "text-success",
    carregando: "text-warning",
    erro: "text-destructive",
  };

  const statusText = {
    pronto: `${browserName} disponível`,
    carregando: `Verificando ${browserName}...`,
    erro: `${browserName} indisponível`,
