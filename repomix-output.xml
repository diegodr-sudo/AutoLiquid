"""Integração Turso via SQL over HTTP.

Usamos HTTP no piloto porque evita dependências nativas do driver libSQL e
funciona bem para sincronizações pontuais do cache local.
"""

from __future__ import annotations

import json
import time
from typing import Any

import requests

from services.config_service import carregar_config_app

_SCHEMA_OK = False


def _config() -> tuple[str, str]:
    cfg = carregar_config_app()
    url = str(cfg.get("turso_database_url") or "").strip()
    token = str(cfg.get("turso_auth_token") or "").strip()
    return url, token


def turso_configurado() -> bool:
    url, token = _config()
    return bool(url and token)


def _pipeline_url() -> str:
    url, _token = _config()
    if not url:
        raise RuntimeError("URL do Turso não configurada.")
    if url.startswith("libsql://"):
        url = "https://" + url.removeprefix("libsql://")
    return url.rstrip("/") + "/v2/pipeline"


def _arg(value: Any) -> dict[str, str]:
    if value is None:
        return {"type": "null", "value": ""}
    if isinstance(value, bool):
        return {"type": "integer", "value": "1" if value else "0"}
    if isinstance(value, int):
        return {"type": "integer", "value": str(value)}
    if isinstance(value, float):
        return {"type": "float", "value": str(value)}
    return {"type": "text", "value": str(value)}


def executar(sql: str, args: list[Any] | tuple[Any, ...] | None = None, *, timeout: float = 10) -> dict[str, Any]:
    _url, token = _config()
    if not token:
        raise RuntimeError("Token do Turso não configurado.")

    stmt: dict[str, Any] = {"sql": sql}
    if args:
        stmt["args"] = [_arg(item) for item in args]

    response = requests.post(
        _pipeline_url(),
        headers={
            "Authorization": f"Bearer {token}",
            "Content-Type": "application/json",
        },
        json={"requests": [{"type": "execute", "stmt": stmt}, {"type": "close"}]},
        timeout=timeout,
    )
    if not response.ok:
        raise RuntimeError(f"Turso respondeu HTTP {response.status_code}: {response.text[:300]}")

    data = response.json()
    result = (data.get("results") or [{}])[0]
    if result.get("type") != "ok":
        raise RuntimeError(f"Turso recusou a consulta: {json.dumps(result, ensure_ascii=False)[:500]}")
    return result.get("response", {}).get("result", {})


def executar_pipeline(
    statements: list[tuple[str, list[Any] | tuple[Any, ...] | None]],
    *,
    timeout: float = 20,
) -> list[dict[str, Any]]:
    _url, token = _config()
    if not token:
        raise RuntimeError("Token do Turso não configurado.")
    if not statements:
        return []

    requests_payload: list[dict[str, Any]] = []
    for sql, args in statements:
        stmt: dict[str, Any] = {"sql": sql}
        if args:
            stmt["args"] = [_arg(item) for item in args]
        requests_payload.append({"type": "execute", "stmt": stmt})
    requests_payload.append({"type": "close"})

    response = requests.post(
        _pipeline_url(),
        headers={
            "Authorization": f"Bearer {token}",
            "Content-Type": "application/json",
        },
        json={"requests": requests_payload},
        timeout=timeout,
    )
    if not response.ok:
        raise RuntimeError(f"Turso respondeu HTTP {response.status_code}: {response.text[:300]}")

    data = response.json()
    results = data.get("results") or []
    for result in results[:-1]:
        if result.get("type") != "ok":
            raise RuntimeError(f"Turso recusou a consulta: {json.dumps(result, ensure_ascii=False)[:500]}")
    return [
        (result.get("response", {}) or {}).get("result", {})
        for result in results
        if result.get("type") == "ok"
    ]


def garantir_schema_cache(*, timeout: float = 10) -> None:
    global _SCHEMA_OK
    if _SCHEMA_OK:
        return
    executar_pipeline(
        [
            (
                """
                create table if not exists cache_snapshots (
                  chave text primary key,
                  payload text not null,
                  atualizado_em text
                )
                """,
                None,
            ),
            (
                """
                create table if not exists contrato_ic_de_para (
                  sarf text primary key,
                  ig text not null,
                  cnpj text,
                  razao_social text,
                  atualizado_em text default current_timestamp
                )
                """,
                None,
            ),
            (
                """
                create table if not exists fila_processos_atual (
                  chave text primary key,
                  numero_processo text,
                  sol_pagamento text,
                  protocolo text,
                  competencia text,
                  dados text not null default '{}',
                  responsavel_manual text,
                  responsavel_manual_por text,
                  responsavel_manual_em text,
                  concluido integer not null default 0,
                  concluido_por text,
                  concluido_em text,
                  presente integer not null default 1,
                  atualizado_em text default current_timestamp
                )
                """,
                None,
            ),
            (
                """
                create table if not exists fila_processos_alertas (
                  id integer primary key autoincrement,
                  chave text not null,
                  numero_processo text,
                  sol_pagamento text,
                  mensagem text not null,
                  autor text,
                  ativo integer not null default 1,
                  criado_em text default current_timestamp
                )
                """,
                None,
            ),
            ("create index if not exists idx_fila_alertas_chave on fila_processos_alertas(chave, ativo, criado_em)", None),
            (
                """
                create table if not exists servidores_config (
                  nome text primary key,
                  nome_completo text,
                  cor text,
                  ordem integer default 0,
                  criado_em text default current_timestamp
                )
                """,
                None,
            ),
            (
                """
                create table if not exists tabelas_operacionais (
                  chave text primary key,
                  dados text not null,
                  atualizado_em text default current_timestamp
                )
                """,
                None,
            ),
            (
                """
                create table if not exists ausencias (
                  id text primary key,
                  servidor text not null,
                  tipo text not null,
                  inicio text not null,
                  fim text not null,
                  obs text
                )
                """,
                None,
            ),
        ],
        timeout=timeout,
    )
    _SCHEMA_OK = True


def testar_conexao() -> dict[str, Any]:
    inicio = time.perf_counter()
    garantir_schema_cache()
    result = executar("select 1 as ok")
    duracao_ms = round((time.perf_counter() - inicio) * 1000, 1)
    return {
        "configured": True,
        "ok": True,
        "durationMs": duracao_ms,
        "rowsRead": result.get("rows_read"),
        "rowsWritten": result.get("rows_written"),
    }


def salvar_snapshot_fila(rows: list[dict[str, Any]], updated_at: str | None) -> None:
    garantir_schema_cache()
    payload = json.dumps(rows or [], ensure_ascii=False, separators=(",", ":"))
    statements: list[tuple[str, list[Any] | tuple[Any, ...] | None]] = [
        (
            """
            insert into cache_snapshots (chave, payload, atualizado_em)
            values (?, ?, ?)
            on conflict(chave) do update set
              payload = excluded.payload,
              atualizado_em = excluded.atualizado_em
            """,
            ["fila_processos_atual", payload, updated_at],
        ),
        ("update fila_processos_atual set presente = 0", None),
    ]
    for row in rows or []:
        chave = _fila_row_key(row)
        responsavel_manual = str(row.get("__responsavel_manual") or "").strip() or None
        responsavel_manual_por = str(row.get("__responsavel_alterado_por") or "").strip() or None
        responsavel_manual_em = str(row.get("__responsavel_alterado_em") or "").strip() or None
        concluido = 1 if str(row.get("__concluido") or "") == "1" else 0
        concluido_por = str(row.get("__concluido_por") or "").strip() or None
        concluido_em = str(row.get("__concluido_em") or "").strip() or None
        statements.append(
            (
                """
                insert into fila_processos_atual (
                  chave, numero_processo, sol_pagamento, protocolo, competencia, dados,
                  responsavel_manual, responsavel_manual_por, responsavel_manual_em,
                  concluido, concluido_por, concluido_em, presente, atualizado_em
                )
                values (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, 1, current_timestamp)
                on conflict(chave) do update set
                  numero_processo = excluded.numero_processo,
                  sol_pagamento = excluded.sol_pagamento,
                  protocolo = excluded.protocolo,
                  competencia = excluded.competencia,
                  dados = excluded.dados,
                  responsavel_manual = coalesce(excluded.responsavel_manual, fila_processos_atual.responsavel_manual),
                  responsavel_manual_por = coalesce(excluded.responsavel_manual_por, fila_processos_atual.responsavel_manual_por),
                  responsavel_manual_em = coalesce(excluded.responsavel_manual_em, fila_processos_atual.responsavel_manual_em),
                  concluido = case when excluded.concluido = 1 then 1 else fila_processos_atual.concluido end,
                  concluido_por = coalesce(excluded.concluido_por, fila_processos_atual.concluido_por),
                  concluido_em = coalesce(excluded.concluido_em, fila_processos_atual.concluido_em),
                  presente = 1,
                  atualizado_em = current_timestamp
                """,
                [
                    chave,
                    str(row.get("Número Processo") or "").strip() or None,
                    str(row.get("Sol. Pagamento") or "").strip() or None,
                    str(row.get("Protocolo") or "").strip() or None,
                    str(row.get("Competência") or "").strip() or None,
                    json.dumps(row, ensure_ascii=False, separators=(",", ":")),
                    responsavel_manual,
                    responsavel_manual_por,
                    responsavel_manual_em,
                    concluido,
                    concluido_por,
                    concluido_em,
                ],
            )
        )
        try:
            alertas = json.loads(str(row.get("__alertas_json") or "[]"))
        except Exception:
            alertas = []
        for alerta in alertas if isinstance(alertas, list) else []:
            if not isinstance(alerta, dict):
                continue
            statements.append(
                (
                    """
                    insert or ignore into fila_processos_alertas
                      (id, chave, numero_processo, sol_pagamento, mensagem, autor, ativo, criado_em)
                    values (?, ?, ?, ?, ?, ?, 1, ?)
                    """,
                    [
                        int(alerta.get("id") or int(time.time() * 1000)),
                        chave,
                        str(row.get("Número Processo") or "").strip() or None,
                        str(row.get("Sol. Pagamento") or "").strip() or None,
                        str(alerta.get("mensagem") or "").strip(),
                        str(alerta.get("autor") or "").strip() or None,
                        str(alerta.get("criadoEm") or "").strip() or time.strftime("%Y-%m-%dT%H:%M:%S"),
                    ],
                )
            )
    executar_pipeline(statements, timeout=25)


def salvar_contratos_ic_de_para(rows: list[dict[str, Any]]) -> None:
    if not turso_configurado():
        return

    garantir_schema_cache(timeout=15)
    normalized: list[dict[str, str]] = []
    for row in rows or []:
        sarf = str((row or {}).get("sarf") or "").strip()
        ig = str((row or {}).get("ig") or "").strip()
        if not sarf or not ig:
            continue
        normalized.append(
            {
                "sarf": sarf,
                "ig": ig,
                "cnpj": str((row or {}).get("cnpj") or "").strip(),
                "razaoSocial": str((row or {}).get("razaoSocial") or "").strip(),
            }
        )

    payload = json.dumps(normalized, ensure_ascii=False, separators=(",", ":"))
    executar(
        """
        insert into cache_snapshots (chave, payload, atualizado_em)
        values ('contrato_ic_de_para', ?, current_timestamp)
        on conflict(chave) do update set
          payload = excluded.payload,
          atualizado_em = excluded.atualizado_em
        """,
        [payload],
        timeout=15,
    )


def obter_contratos_ic_de_para() -> dict[str, str]:
    if not turso_configurado():
        return {}

    garantir_schema_cache(timeout=4)
    snapshot = executar(
        """
        select payload
        from cache_snapshots
        where chave = 'contrato_ic_de_para'
        """,
        timeout=4,
    )
    mapa: dict[str, str] = {}
    snapshot_rows = snapshot.get("rows") or []
    if snapshot_rows:
        payload = _cell_value(snapshot_rows[0][0]) if snapshot_rows[0] else "[]"
        try:
            rows = json.loads(str(payload or "[]"))
        except Exception:
            rows = []
        for row in rows if isinstance(rows, list) else []:
            if not isinstance(row, dict):
                continue
            sarf = str(row.get("sarf") or "").strip().upper()
            ig = str(row.get("ig") or "").strip()
            if sarf and ig:
                mapa[sarf] = ig
        if mapa:
            return mapa

    result = executar("select sarf, ig from contrato_ic_de_para", timeout=4)
    for row in result.get("rows") or []:
        sarf = str(_cell_value(row[0]) if len(row) > 0 else "").strip().upper()
        ig = str(_cell_value(row[1]) if len(row) > 1 else "").strip()
        if sarf and ig:
            mapa[sarf] = ig
    return mapa


def _cell_value(cell: Any) -> Any:
    if isinstance(cell, dict):
        if cell.get("type") == "null":
            return None
        return cell.get("value")
    return cell


def _row_to_dict(result: dict[str, Any], row: list[Any]) -> dict[str, Any]:
    cols = [str(col.get("name") or "") for col in result.get("cols") or []]
    return {
        cols[index]: _cell_value(cell)
        for index, cell in enumerate(row or [])
        if index < len(cols) and cols[index]
    }


def _nome_servidor_simples(nome: str) -> str:
    partes = str(nome or "").strip().split()
    return partes[0] if partes else ""


def _fila_row_key(row: dict[str, Any]) -> str:
    numero = str(row.get("Número Processo") or row.get("numeroProcesso") or row.get("numero_processo") or "").strip()
    sol = str(row.get("Sol. Pagamento") or row.get("solPagamento") or row.get("sol_pagamento") or "").strip()
    return f"{numero}::{sol}"


def _mesclar_override_fila(row: dict[str, Any], meta: dict[str, Any], alertas: list[dict[str, Any]]) -> dict[str, Any]:
    merged = dict(row or {})
    responsavel = str(meta.get("responsavel_manual") or "").strip()
    if responsavel:
        merged["__responsavel_manual"] = responsavel
        merged["__responsavel_alterado"] = "1"
        merged["__responsavel_alterado_por"] = str(meta.get("responsavel_manual_por") or "").strip()
        merged["__responsavel_alterado_em"] = str(meta.get("responsavel_manual_em") or "").strip()
    else:
        merged["__responsavel_manual"] = ""
        merged["__responsavel_alterado"] = ""
        merged["__responsavel_alterado_por"] = ""
        merged["__responsavel_alterado_em"] = ""
    merged["__alertas_json"] = json.dumps(alertas or [], ensure_ascii=False)
    merged["__concluido"] = "1" if str(meta.get("concluido") or "0") in {"1", "true", "True"} else ""
    merged["__concluido_por"] = str(meta.get("concluido_por") or "").strip()
    merged["__concluido_em"] = str(meta.get("concluido_em") or "").strip()
    return merged


def obter_snapshot_fila(*, timeout: float = 2.5) -> dict[str, Any]:
    if not turso_configurado():
        return {"rows": [], "updatedAt": None}

    garantir_schema_cache(timeout=timeout)
    table_result = executar(
        """
        select chave, dados, responsavel_manual, responsavel_manual_por, responsavel_manual_em,
               concluido, concluido_por, concluido_em, atualizado_em
        from fila_processos_atual
        where presente = 1
        order by competencia asc, numero_processo asc, chave asc
        """,
        timeout=timeout,
    )
    table_rows = [_row_to_dict(table_result, row) for row in table_result.get("rows") or []]
    if table_rows:
        chaves = [str(row.get("chave") or "") for row in table_rows if row.get("chave")]
        alertas_por_chave: dict[str, list[dict[str, Any]]] = {}
        if chaves:
            placeholders = ",".join("?" for _ in chaves)
            alert_result = executar(
                f"""
                select chave, id, mensagem, autor, criado_em
                from fila_processos_alertas
                where ativo = 1 and chave in ({placeholders})
                order by criado_em desc, id desc
                """,
                chaves,
                timeout=timeout,
            )
            for alert_row in alert_result.get("rows") or []:
                alerta = _row_to_dict(alert_result, alert_row)
                chave = str(alerta.get("chave") or "")
                alertas_por_chave.setdefault(chave, []).append(
                    {
                        "id": int(alerta.get("id") or 0),
                        "mensagem": str(alerta.get("mensagem") or "").strip(),
                        "autor": str(alerta.get("autor") or "").strip(),
                        "criadoEm": str(alerta.get("criado_em") or "").strip() or None,
                    }
                )

        parsed_rows: list[dict[str, Any]] = []
        updated_values: list[str] = []
        for item in table_rows:
            try:
                base = json.loads(str(item.get("dados") or "{}"))
            except Exception:
                base = {}
            if not isinstance(base, dict):
                base = {}
            chave = str(item.get("chave") or "")
            parsed_rows.append(_mesclar_override_fila(base, item, alertas_por_chave.get(chave, [])))
            if item.get("atualizado_em"):
                updated_values.append(str(item.get("atualizado_em")))
        return {
            "rows": parsed_rows,
            "updatedAt": max(updated_values) if updated_values else None,
        }

    result = executar(
        """
        select payload, atualizado_em
        from cache_snapshots
        where chave = ?
        """,
        ["fila_processos_atual"],
        timeout=timeout,
    )
    rows = result.get("rows") or []
    if not rows:
        return {"rows": [], "updatedAt": None}

    first = rows[0] or []
    payload = _cell_value(first[0]) if len(first) > 0 else "[]"
    updated_at = _cell_value(first[1]) if len(first) > 1 else None
    try:
        parsed = json.loads(str(payload or "[]"))
    except Exception:
        parsed = []

    if not isinstance(parsed, list):
        parsed = []

    return {
        "rows": [item for item in parsed if isinstance(item, dict)],
        "updatedAt": updated_at,
    }


def salvar_responsavel_fila(*, numero_processo: str, sol_pagamento: str, responsavel: str, autor: str = "") -> str | None:
    garantir_schema_cache(timeout=8)
    row_key = _fila_row_key({"Número Processo": numero_processo, "Sol. Pagamento": sol_pagamento})
    alterado_em = time.strftime("%Y-%m-%dT%H:%M:%S")
    executar(
        """
        insert into fila_processos_atual (
          chave, numero_processo, sol_pagamento, dados, responsavel_manual,
          responsavel_manual_por, responsavel_manual_em, presente, atualizado_em
        )
        values (?, ?, ?, '{}', ?, ?, case when nullif(?, '') is null then null else ? end, 1, current_timestamp)
        on conflict(chave) do update set
          numero_processo = excluded.numero_processo,
          sol_pagamento = excluded.sol_pagamento,
          responsavel_manual = excluded.responsavel_manual,
          responsavel_manual_por = excluded.responsavel_manual_por,
          responsavel_manual_em = excluded.responsavel_manual_em,
          atualizado_em = current_timestamp
        """,
        [row_key, numero_processo.strip() or None, sol_pagamento.strip() or None, responsavel.strip() or None, autor or None, responsavel.strip(), alterado_em],
        timeout=8,
    )
    return alterado_em if responsavel.strip() else None


def salvar_conclusao_fila(*, numero_processo: str, sol_pagamento: str, concluido: bool, autor: str = "") -> dict[str, Any]:
    garantir_schema_cache(timeout=8)
    row_key = _fila_row_key({"Número Processo": numero_processo, "Sol. Pagamento": sol_pagamento})
    concluido_em = time.strftime("%Y-%m-%dT%H:%M:%S") if concluido else ""
    concluido_por = autor if concluido else ""
    executar(
        """
        insert into fila_processos_atual (
          chave, numero_processo, sol_pagamento, dados, concluido, concluido_por, concluido_em, presente, atualizado_em
        )
        values (?, ?, ?, '{}', ?, ?, ?, 1, current_timestamp)
        on conflict(chave) do update set
          numero_processo = excluded.numero_processo,
          sol_pagamento = excluded.sol_pagamento,
          concluido = excluded.concluido,
          concluido_por = excluded.concluido_por,
          concluido_em = excluded.concluido_em,
          atualizado_em = current_timestamp
        """,
        [row_key, numero_processo.strip() or None, sol_pagamento.strip() or None, 1 if concluido else 0, concluido_por or None, concluido_em or None],
        timeout=8,
    )
    return {"concluido": concluido, "concluidoPor": concluido_por, "concluidoEm": concluido_em}


def salvar_alerta_fila(*, numero_processo: str, sol_pagamento: str, mensagem: str, autor: str = "") -> dict[str, Any]:
    texto = str(mensagem or "").strip()
    if not texto:
        raise ValueError("Informe uma mensagem para o alerta.")
    garantir_schema_cache(timeout=8)
    row_key = _fila_row_key({"Número Processo": numero_processo, "Sol. Pagamento": sol_pagamento})
    criado_em = time.strftime("%Y-%m-%dT%H:%M:%S")
    result = executar(
        """
        insert into fila_processos_alertas (chave, numero_processo, sol_pagamento, mensagem, autor, ativo, criado_em)
        values (?, ?, ?, ?, ?, 1, ?)
        """,
        [row_key, numero_processo.strip() or None, sol_pagamento.strip() or None, texto, autor or None, criado_em],
        timeout=8,
    )
    return {
        "id": int(result.get("last_insert_rowid") or int(time.time() * 1000)),
        "mensagem": texto,
        "autor": autor,
        "criadoEm": criado_em,
    }


def obter_tabela_operacional(chave: str) -> list[dict[str, Any]] | None:
    garantir_schema_cache(timeout=6)
    result = executar("select dados from tabelas_operacionais where chave = ?", [str(chave or "").strip()], timeout=6)
    rows = result.get("rows") or []
    if not rows:
        return None
    try:
        parsed = json.loads(str(_cell_value(rows[0][0]) or "[]"))
    except Exception:
        parsed = []
    return parsed if isinstance(parsed, list) else []


def salvar_tabela_operacional(chave: str, rows: list[dict[str, Any]]) -> None:
    garantir_schema_cache(timeout=8)
    executar(
        """
        insert into tabelas_operacionais (chave, dados, atualizado_em)
        values (?, ?, current_timestamp)
        on conflict(chave) do update set dados = excluded.dados, atualizado_em = current_timestamp
        """,
        [str(chave or "").strip(), json.dumps(rows or [], ensure_ascii=False, separators=(",", ":"))],
        timeout=8,
    )


def listar_servidores_config() -> list[dict[str, Any]]:
    garantir_schema_cache(timeout=6)
    result = executar(
        """
        select nome, nome_completo, cor
        from servidores_config
        order by coalesce(ordem, 999999), criado_em, nome
        """,
        timeout=6,
    )
    rows: list[dict[str, Any]] = []
    for raw in result.get("rows") or []:
        row = _row_to_dict(result, raw)
        nome_completo = str(row.get("nome_completo") or row.get("nome") or "").strip()
        nome = str(row.get("nome") or _nome_servidor_simples(nome_completo)).strip()
        rows.append({"nome": nome or nome_completo, "nomeCompleto": nome_completo or nome, "cor": str(row.get("cor") or "#6366f1")})
    return rows


def salvar_servidor_config(nome: str, cor: str) -> None:
    garantir_schema_cache(timeout=8)
    nome_completo = str(nome or "").strip()
    if not nome_completo:
        raise ValueError("Nome do servidor é obrigatório.")
    nome_simples = _nome_servidor_simples(nome_completo)
    executar(
        """
        insert into servidores_config (nome, nome_completo, cor, criado_em)
        values (?, ?, ?, current_timestamp)
        on conflict(nome) do update set
          nome_completo = excluded.nome_completo,
          cor = excluded.cor
        """,
        [nome_simples, nome_completo, str(cor or "#6366f1").strip() or "#6366f1"],
        timeout=8,
    )


def deletar_servidor_config(nome: str) -> None:
    garantir_schema_cache(timeout=8)
    nome_limpo = str(nome or "").strip()
    nome_simples = _nome_servidor_simples(nome_limpo)
    executar("delete from servidores_config where lower(nome) = lower(?) or lower(nome_completo) = lower(?)", [nome_simples, nome_limpo], timeout=8)


def listar_ausencias() -> list[dict[str, Any]]:
    garantir_schema_cache(timeout=6)
    result = executar("select id, servidor, tipo, inicio, fim, obs from ausencias order by inicio, servidor", timeout=6)
    return [
        {
            "id": str(row.get("id") or ""),
            "servidor": str(row.get("servidor") or ""),
            "tipo": str(row.get("tipo") or ""),
            "inicio": str(row.get("inicio") or ""),
            "fim": str(row.get("fim") or ""),
            "obs": row.get("obs"),
        }
        for row in (_row_to_dict(result, raw) for raw in result.get("rows") or [])
    ]


def criar_ausencia(ausencia: dict[str, Any]) -> dict[str, Any]:
    garantir_schema_cache(timeout=8)
    item = {
        "id": str(ausencia["id"]),
        "servidor": str(ausencia["servidor"]).strip(),
        "tipo": str(ausencia["tipo"]),
        "inicio": str(ausencia["inicio"]),
        "fim": str(ausencia["fim"]),
        "obs": str(ausencia.get("obs") or "").strip() or None,
    }
    executar(
        """
        insert into ausencias (id, servidor, tipo, inicio, fim, obs)
        values (?, ?, ?, ?, ?, ?)
        on conflict(id) do update set
          servidor = excluded.servidor,
          tipo = excluded.tipo,
          inicio = excluded.inicio,
          fim = excluded.fim,
          obs = excluded.obs
        """,
        [item["id"], item["servidor"], item["tipo"], item["inicio"], item["fim"], item["obs"]],
        timeout=8,
    )
    return item


def deletar_ausencia(ausencia_id: str) -> bool:
    garantir_schema_cache(timeout=8)
    result = executar("delete from ausencias where id = ?", [str(ausencia_id)], timeout=8)
    return int(result.get("affected_row_count") or 0) > 0
