    </tr>
  );
}

export function GlassTableCell({ children, className, compact }: { children: ReactNode; className?: string; compact?: boolean }) {
  return (
    <td className={cn(compact ? "px-2 py-2" : "px-4 py-3", "text-sm text-foreground", className)}>
      {children}
    </td>
  );
}
