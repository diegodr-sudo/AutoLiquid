    return (
        str(valor or "")
        .replace("DeduÃ§Ã£o", "Dedução")
        .replace("ExecuÃ§Ã£o", "Execução")
        .replace("ConfirmaÃ§Ã£o", "Confirmação")
        .replace("SituaÃ§Ã£o", "Situação")
        .replace("nÃ£o", "não")
        .replace("NÃ£o", "Não")
        .replace("estÃ¡", "está")
        .replace("CÃ³digo", "Código")
        .replace("MunicÃ­pio", "Município")
        .replace("Ã¡", "á")
        .replace("Ã¢", "â")
        .replace("Ã£", "ã")
        .replace("Ã§", "ç")
        .replace("Ã©", "é")
        .replace("Ãª", "ê")
        .replace("Ã­", "í")
        .replace("Ã³", "ó")
        .replace("Ã´", "ô")
        .replace("Ãµ", "õ")
        .replace("Ãº", "ú")
        .replace("Âº", "º")
