    # â"€â"€ 12. PrÃ©-Doc (seção já aberta — _abrir_predoc_resiliente não reclica) ──
    municipio_nf_nome = nome_mun
    # Aliquota efetiva por NF = ISS_NF / Valor_NF x 100 (ex: 1706,07 / 68242,70 = 2,50%).
