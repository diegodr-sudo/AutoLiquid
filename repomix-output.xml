    return () => { ativo = false; };
  // filaCnpjsKey muda apenas quando os CNPJs da fila mudam — não quando metadados locais são atualizados.
  // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [filaCnpjsKey, mostrarSimples]);

